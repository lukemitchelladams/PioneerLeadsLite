# Supabase (get these from supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — used SERVER-SIDE ONLY to create user accounts
# Get from supabase.com → Project Settings → API → service_role key
# NEVER share this key or put it in client-side code
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# The answer to your staff account creation security question:
# "What is the middle name of the person that created this app?"
# Set this to the answer (case-insensitive, spaces trimmed automatically)
SECRET_ANSWER=YourMiddleNameHere
